---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { 
  ArrowRight, 
  Sparkles, 
  Clock, 
  BookOpen, 
  Users,
  ChevronRight,
  Search,
  Filter,
  Star,
  Award,
  Target,
  Compass,
  Layers,
  PenTool,
  MapPin,
  Building,
  Heart,
  GraduationCap,
  FlaskConical,
  Microscope,
  Leaf,
  Palette,
  Laptop,
  Utensils,
  Briefcase,
  Medal,
  Rocket,
  DollarSign,
  Calendar,
  Bookmark,
  Share2,
  Download,
  TrendingUp,
  Zap,
  Brain,
  CheckCircle,
  FileText,
  AlertCircle,
  BarChart,
  Lightbulb,
  PlayCircle,
  ChevronDown
} from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const pillars = [...new Set(posts.map(post => post.data.pillar))];
  
  return pillars.map(pillar => {
    // Current pillar hub page
    const hubPost = posts.find(post => post.data.pillar === pillar && post.data.type === 'hub');
    
    // All other posts in this pillar (articles and money pages)
    const pillarPosts = posts.filter(post => post.data.pillar === pillar && post.data.type !== 'hub');
    
    // Group posts by subcategory
    const subcategories = pillarPosts.reduce((acc, post) => {
      const subcat = post.data.subcategory;
      if (!acc[subcat]) {
        acc[subcat] = {
          name: subcat.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
          slug: subcat,
          posts: [],
          count: 0
        };
      }
      acc[subcat].posts.push(post);
      acc[subcat].count++;
      return acc;
    }, {});
    
    // Get unique tags from pillar posts
    const tags = new Map();
    pillarPosts.forEach(post => {
      post.data.tags?.forEach(tag => {
        tags.set(tag, (tags.get(tag) || 0) + 1);
      });
    });
    
    // Sort posts by date
    const latestPosts = pillarPosts.sort((a, b) => 
      new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
    );
    
    // Get featured/evergreen posts (oldest but most important)
    const featuredPosts = pillarPosts
      .filter(post => post.data.tags?.includes('featured') || post.data.tags?.includes('evergreen'))
      .slice(0, 3);
    
    // If no featured tags, take 3 most recent as featured
    const featured = featuredPosts.length ? featuredPosts : latestPosts.slice(0, 3);
    
    return {
      params: { pillar },
      props: { 
        subcategories: Object.values(subcategories),
        tags: Array.from(tags.entries()).sort((a, b) => b[1] - a[1]).slice(0, 12),
        latestPosts: latestPosts.slice(0, 6),
        featuredPosts: featured,
        totalPosts: pillarPosts.length,
        totalSubcategories: Object.keys(subcategories).length
      }
    };
  });
}

const { pillar } = Astro.params;
const { subcategories, tags, latestPosts, featuredPosts, totalPosts, totalSubcategories } = Astro.props;

// Pillar configuration - matches blog homepage
