        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {subcategories.map((sub) => {
          // Get a sample post from this subcategory for preview
          const samplePost = sub.posts[0];
          // Get unique tags within this subcategory
          const subTags = [...new Set(sub.posts.flatMap(p => p.data.tags || []))].slice(0, 3);
          
          return (
            <a 
              href={`/blog/${pillar}/${sub.slug}`}
              class="group relative bg-card border border-border rounded-2xl p-6 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 overflow-hidden"
