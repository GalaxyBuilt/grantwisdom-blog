                  <span class="inline-flex items-center gap-1 text-xs font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                    Explore <ArrowRight class="h-3 w-3" />
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Popular Tags within Pillar -->
    {tags.length > 0 && (
      <section class="bg-secondary/40 border-y border-border">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
