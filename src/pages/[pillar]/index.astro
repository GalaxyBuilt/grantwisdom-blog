              <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
                <span class={`px-2 py-1 rounded-full ${gradientStyle} bg-opacity-10 text-foreground font-medium`}>
                  {post.data.subcategory.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}
                </span>
                <span>•</span>
                <span class="flex items-center gap-1">
                  <Clock class="h-3 w-3" />
                  {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
              
              <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              
              <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                {post.data.description}
              </p>
              
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-foreground">
                  {post.data.author}
                </span>
                <span class="inline-flex items-center gap-1 text-sm text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                  Read <ArrowRight class="h-4 w-4" />
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Features Section - Pillar specific -->
    {config.features.length > 0 && (
      <section class="bg-gradient-to-b from-background to-secondary/30 border-y border-border">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
          <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div>
              <div class={`inline-flex items-center gap-2 rounded-full border ${config.border} ${config.bgLight} px-4 py-1.5 text-sm ${config.text} font-medium mb-6`}>
                <Zap class="h-3.5 w-3.5" />
                What you'll learn
              </div>
              
              <h2 class="text-3xl font-bold text-foreground mb-6">
                Master {config.label.toLowerCase()} with our comprehensive guides
              </h2>
              
              <div class="space-y-4 mb-8">
                {config.features.map((feature, index) => (
                  <div key={index} class="flex items-start gap-3">
                    <div class={`shrink-0 w-6 h-6 rounded-full ${gradientStyle} flex items-center justify-center mt-0.5`}>
                      <CheckCircle class="h-4 w-4 text-white" />
                    </div>
                    <span class="text-foreground">{feature}</span>
                  </div>
                ))}
              </div>
              
              <a 
                href={`/blog/${pillar}/`}
                class="inline-flex items-center gap-2 px-6 py-3 bg-card border border-border rounded-xl hover:border-primary/30 hover:shadow-lg transition-all group"
              >
                <span class="font-medium">Start learning</span>
                <ArrowRight class="h-4 w-4 group-hover:translate-x-1 transition-transform" />
              </a>
            </div>
            
            <div class="relative">
              <div class={`absolute -inset-4 bg-gradient-to-r ${config.color} rounded-3xl blur-2xl opacity-20`} />
              <div class="relative bg-card border border-border rounded-2xl p-8 shadow-xl">
                <div class="flex items-center gap-3 mb-6">
                  <div class={`w-10 h-10 rounded-xl ${gradientStyle} flex items-center justify-center`}>
                    <Lightbulb class="h-5 w-5 text-white" />
                  </div>
                  <h3 class="font-bold text-foreground">Pro Tip</h3>
                </div>
                <p class="text-muted-foreground mb-6">
                  Start with our beginner's guide to {config.label.toLowerCase()}, then explore specific subcategories based on your interests and experience level.
                </p>
                <div class="flex items-center gap-4 pt-4 border-t border-border">
                  <img 
                    src="/avatars/expert.jpg" 
                    alt="Expert" 
                    class="w-10 h-10 rounded-full border-2 border-primary/20"
                    onerror="this.src='https://ui-avatars.com/api/?name=Grant+Expert&background=6366f1&color=fff&size=40'"
                  />
                  <div>
                    <p class="text-sm font-medium text-foreground">Sarah Chen</p>
                    <p class="text-xs text-muted-foreground">Senior Grant Strategist</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Related Pillars -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <h2 class="text-2xl font-bold text-foreground mb-8 text-center">Explore Related Topics</h2>
      
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {Object.entries(pillarConfig)
          .filter(([key]) => key !== pillar)
          .slice(0, 3)
          .map(([key, related]) => {
            const RelatedIcon = related.icon;
            return (
              <a 
                href={`/blog/${key}`}
                class="group bg-card border border-border rounded-xl p-5 hover:border-primary/30 hover:shadow-lg transition-all"
              >
                <div class="flex items-center gap-4">
                  <div class={`w-10 h-10 rounded-lg bg-gradient-to-br ${related.color} bg-opacity-10 flex items-center justify-center`}>
                    <RelatedIcon class="h-5 w-5 text-white" />
                  </div>
                  <div>
                    <h3 class="font-semibold text-foreground group-hover:text-primary transition-colors">
                      {related.label}
                    </h3>
                    <p class="text-xs text-muted-foreground line-clamp-1">
                      {related.description}
                    </p>
                  </div>
                  <ChevronRight class="h-4 w-4 text-muted-foreground ml-auto group-hover:text-primary group-hover:translate-x-1 transition-all" />
                </div>
              </a>
            );
          })}
      </div>
    </section>

    <!-- Newsletter Section -->
    <section class={`bg-gradient-to-b ${config.bgLight} to-transparent border-y ${config.border}`}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <div class={`inline-flex items-center gap-2 rounded-full border ${config.border} ${config.bgLight} px-4 py-1.5 text-sm ${config.text} font-medium mb-6`}>
          <Sparkles class="h-4 w-4" />
          {config.label} Newsletter
        </div>
        
        <h2 class="font-display text-4xl text-foreground mb-4 italic">
          Get {config.label.toLowerCase()} insights
        </h2>
        
        <p class="text-muted-foreground text-lg mb-8 max-w-2xl mx-auto">
          Subscribe to receive the latest articles, guides, and strategies in {config.label.toLowerCase()} directly in your inbox.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="flex-1 h-12 px-4 rounded-xl border border-border bg-card focus:border-primary/30 focus:ring-4 focus:ring-primary/10 transition-all outline-none text-foreground"
          />
          <button class={`h-12 px-6 ${gradientStyle} text-white rounded-xl font-medium hover:opacity-90 transition-opacity`}>
            Subscribe
          </button>
        </div>
        
        <p class="text-xs text-muted-foreground mt-4">
          Join 5,000+ readers. No spam, unsubscribe anytime.
        </p>
      </div>
    </section>

    <!-- CTA to Main App -->
    <section class="bg-secondary/40 border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
        <h2 class="font-display text-4xl text-foreground mb-4 italic">
          Ready to apply these strategies?
        </h2>
        <p class="text-muted-foreground mb-8">
          Put your knowledge into action. Search 200,000+ active grants and start applying today.
        </p>
        <a href="/grants">
          <button class={`h-14 px-8 ${gradientStyle} text-white rounded-xl font-medium hover:opacity-90 transition-opacity inline-flex items-center gap-2 text-lg shadow-lg shadow-primary/20`}>
            Search Grants
            <ArrowRight class="h-5 w-5" />
          </button>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
