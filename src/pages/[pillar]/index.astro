              {config.label}<br />
              <span class={`gradient-text bg-gradient-to-r ${config.color} italic`}>Resources</span>
            </h1>
            
            <p class="text-lg text-muted-foreground max-w-xl mb-6 leading-relaxed">
              {config.description}
            </p>

            <p class="text-sm text-muted-foreground mb-8 italic border-l-4 pl-4 border-primary/20">
              {config.audience}
            </p>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-8 mb-10">
