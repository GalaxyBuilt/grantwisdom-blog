                <div class="flex items-center justify-between mb-4">
                  <div class={`w-12 h-12 rounded-xl ${gradientStyle} bg-opacity-10 flex items-center justify-center`}>
                    <Icon class="h-6 w-6 text-white" />
                  </div>
                  <span class="text-2xl font-bold text-muted-foreground/20">{sub.count}</span>
                </div>
                
                <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
                  {sub.name}
                </h3>
                
                {samplePost && (
                  <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                    {samplePost.data.description}
