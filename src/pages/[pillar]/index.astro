            <div>
              <h2 class="text-2xl font-bold text-foreground mb-2">Popular Topics</h2>
              <p class="text-muted-foreground">Most discussed tags in {config.label.toLowerCase()}</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            {tags.map(([tag, count]) => (
              <a 
                href={`/blog/tag/${tag}`}
                class="group px-4 py-2 bg-card border border-border rounded-full hover:border-primary/30 hover:bg-primary/5 transition-all"
              >
                <span class="text-sm font-medium text-foreground">#{tag}</span>
                <span class="text-xs text-muted-foreground ml-2">({count})</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Latest Articles in this Pillar -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
