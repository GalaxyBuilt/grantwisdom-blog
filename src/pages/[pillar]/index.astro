const config = pillarConfig[pillar] || {
  label: pillar.charAt(0).toUpperCase() + pillar.slice(1).replace(/-/g, ' '),
  icon: BookOpen,
  description: 'Expert guides and resources',
  color: 'from-primary to-primary/50',
  bgLight: 'bg-primary/10',
  border: 'border-primary/20',
  text: 'text-primary',
  features: [],
  audience: 'For grant seekers of all levels'
};

const Icon = config.icon;
const gradientStyle = `bg-gradient-to-br ${config.color}`;
---

<BaseLayout title={`${config.label} Resources | Blog`}>
  <main class="flex-grow bg-background">
    <!-- Hero Section - Pillar specific -->
    <section class="relative overflow-hidden border-b border-border">
      <!-- Background gradient -->
      <div class={`absolute inset-0 ${config.bgLight} opacity-30`} />
      <div class={`absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l ${config.color} opacity-5`} />
      
      <!-- Decorative elements -->
      <div class="absolute top-20 left-10 w-64 h-64 rounded-full bg-primary/5 blur-3xl" />
      <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full bg-primary/10 blur-3xl" />
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20 relative">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-sm text-muted-foreground mb-8">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <ChevronRight class="h-4 w-4" />
          <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
          <ChevronRight class="h-4 w-4" />
          <span class={`font-medium ${config.text}`}>{config.label}</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left column -->
