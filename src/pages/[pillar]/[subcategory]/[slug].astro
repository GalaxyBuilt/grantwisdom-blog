---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Calendar, Clock, ArrowLeft, Share2, Bookmark, MessageSquare, Compass, ArrowRight } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.type !== 'hub');
  return posts.map(post => ({
    params: { 
      pillar: post.data.pillar, 
      subcategory: post.data.subcategory, 
      slug: post.data.slug 
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { pillar, subcategory } = Astro.params;
const { Content, headings } = await render(post);

// Calculate reading time (roughly 200 words per minute)
const wordCount = post.body?.split(/\s+/).length || 500;
const readTime = Math.ceil(wordCount / 200);

// Pillar formatting
const pillarLabels: Record<string, string> = {
  'grant-guides': 'Grant Guides',
  'grant-writing': 'Grant Writing',
  'grants-by-industry': 'By Industry',
  'grants-by-location': 'By Location',
  'grants-by-demographic': 'By Demographic',
  'grant-programs': 'Grant Programs',
  'grant-strategy': 'Grant Strategy'
};
---

<BaseLayout 
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedDate={new Date(post.data.publishedAt).toISOString()}
  author={post.data.author}
  image={post.data.featuredImage}
>
  <main class="flex-grow bg-background relative overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-1/3 h-1/2 bg-primary/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2" />
    <div class="absolute bottom-0 left-0 w-1/4 h-1/3 bg-secondary/10 blur-[100px] rounded-full translate-y-1/2 -translate-x-1/2" />

    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 relative">
      <!-- Back / Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-12">
        <a href="/blog/" class="hover:text-primary transition-colors flex items-center gap-1">
          <ArrowLeft class="w-4 h-4" /> Blog
        </a>
        <span>/</span>
        <a href={`/blog/${pillar}/`} class="hover:text-primary transition-colors capitalize">
          {pillarLabels[pillar] || pillar.replace(/-/g, ' ')}
        </a>
        <span>/</span>
        <span class="text-primary font-medium truncate">{post.data.title}</span>
      </nav>

      {/* Post Header */}
      <header class="mb-16">
        <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm text-primary font-medium mb-8">
          <span class="capitalize">{subcategory.replace(/-/g, ' ')}</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display text-foreground mb-8 leading-[1.1] tracking-tight">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center justify-between gap-6 border-y border-border py-8">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-primary to-primary/60 rounded-full flex items-center justify-center font-bold text-white shadow-lg shadow-primary/20">
              {post.data.author.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <p class="font-bold text-foreground">{post.data.author}</p>
              <div class="flex items-center gap-3 text-sm text-muted-foreground">
                <span class="flex items-center gap-1"><Calendar class="w-3.5 h-3.5" /> {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                <span class="flex items-center gap-1"><Clock class="w-3.5 h-3.5" /> {readTime} min read</span>
              </div>
            </div>
          </div>
          
          <div class="flex items-center gap-2">
            <button class="p-2.5 rounded-xl bg-card border border-border hover:border-primary/30 hover:bg-primary/5 transition-all text-muted-foreground hover:text-primary">
              <Share2 class="w-5 h-5" />
            </button>
            <button class="p-2.5 rounded-xl bg-card border border-border hover:border-primary/30 hover:bg-primary/5 transition-all text-muted-foreground hover:text-primary">
              <Bookmark class="w-5 h-5" />
            </button>
          </div>
        </div>
      </header>

      {/* Featured Image */}
      {post.data.featuredImage && (
        <figure class="mb-16 -mx-4 sm:mx-0">
          <div class="aspect-[21/9] rounded-[2rem] overflow-hidden border border-border/50 shadow-2xl">
            <img 
              src={post.data.featuredImage} 
              alt={post.data.title} 
              class="w-full h-full object-cover"
            />
          </div>
        </figure>
      )}

      {/* Article Content Grid */}
      <div class="grid lg:grid-cols-[1fr_250px] gap-16">
        <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none 
          prose-headings:font-display prose-headings:tracking-tight prose-headings:text-foreground
          prose-p:text-muted-foreground/90 prose-p:leading-relaxed
          prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
          prose-a:text-primary prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-3xl prose-img:border prose-img:border-border
        ">
          <Content />
          
          {/* Tags */}
          <div class="mt-16 pt-8 border-t border-border flex flex-wrap gap-2">
            {post.data.tags.map(tag => (
              <a href={`/blog/tag/${tag}/`} class="px-4 py-1.5 rounded-full bg-secondary border border-border text-sm font-medium text-muted-foreground hover:border-primary/30 hover:text-primary transition-all">
                #{tag}
              </a>
            ))}
          </div>
        </div>

        {/* Sidebar */}
        <aside class="hidden lg:block space-y-12">
          {/* Table of Contents */}
          {headings.length > 0 && (
            <div class="sticky top-24">
              <h4 class="text-sm font-bold text-foreground uppercase tracking-widest mb-6 flex items-center gap-2">
                <Compass class="w-4 h-4" /> Table of Contents
              </h4>
              <nav class="space-y-3">
                {headings.filter(h => h.depth <= 3).map(h => (
                  <a 
                    href={`#${h.slug}`} 
                    class={`block text-sm transition-all hover:text-primary ${h.depth === 3 ? 'pl-4 text-muted-foreground/70' : 'font-medium text-muted-foreground'}`}
                  >
                    {h.text}
                  </a>
                ))}
              </nav>
              
              {/* Call to Action Card */}
              <div class="mt-12 p-6 rounded-2xl bg-gradient-to-br from-primary to-primary/80 text-white shadow-xl shadow-primary/20">
                <h5 class="font-bold mb-2">Need a Grant?</h5>
                <p class="text-xs text-white/80 mb-4 leading-relaxed">Search 200,000+ active grants and get AI-matched today.</p>
                <a href="https://grantwisdom.com/grants" class="inline-flex items-center gap-1.5 text-xs font-bold bg-white text-primary px-4 py-2 rounded-lg hover:bg-opacity-90 transition-all">
                  Search Now <ArrowRight class="w-3.5 w-3.5" />
                </a>
              </div>
            </div>
          )}
        </aside>
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  /* Smooth scroll for TOC */
  html {
    scroll-behavior: smooth;
  }
  
  /* Targeted heading scroll padding */
  h2, h3 {
    scroll-margin-top: 100px;
  }
</style>
