---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { Calendar, Clock, ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { 
      pillar: post.data.pillar, 
      subcategory: post.data.subcategory, 
      slug: post.id 
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { pillar, subcategory } = Astro.params;
const { Content } = await render(post);
---

<BaseLayout 
  title={post.data.title}
  description={post.data.excerpt}
  type="article"
  publishedDate={new Date(post.data.date).toISOString()}
  author={post.data.author}
>
  <main class="flex-grow bg-background py-20">
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Back Button */}
      <a 
        href="/blog" 
        class="inline-flex items-center gap-2 text-sm font-black text-muted-foreground hover:text-accent uppercase tracking-tighter mb-12 transition-colors"
      >
        <ArrowLeft class="w-4 h-4" /> Back to Blog
      </a>

      {/* Post Header */}
      <header class="mb-12">
        <div class="flex items-center gap-4 text-xs font-black text-accent uppercase tracking-widest mb-6">
          <span class="bg-accent/10 px-3 py-1 rounded-full">{post.data.category}</span>
          <span class="text-muted-foreground">/</span>
          <span class="text-muted-foreground capitalize">{pillar}</span>
          <span class="text-muted-foreground">/</span>
          <span class="text-muted-foreground capitalize">{subcategory.replace(/-/g, ' ')}</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-black text-foreground mb-8 tracking-tight leading-tight">
          {post.data.title}
        </h1>
        <div class="flex items-center justify-between border-y border-border py-6">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center font-black text-accent-foreground text-xs uppercase">
              {post.data.author.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-black text-foreground">{post.data.author}</p>
              <p class="text-xs text-muted-foreground font-medium">Contributor</p>
            </div>
          </div>
          <div class="flex gap-4 text-muted-foreground items-center">
            <Calendar class="w-4 h-4" /> <span class="text-xs">{post.data.date}</span>
            <Clock class="w-4 h-4" /> <span class="text-xs">{post.data.readTime}</span>
          </div>
        </div>
      </header>

      <div class="prose prose-lg prose-neutral dark:prose-invert max-w-none 
        prose-headings:font-black prose-headings:tracking-tight prose-headings:text-foreground
        prose-p:text-muted-foreground prose-p:font-medium prose-p:leading-relaxed
        prose-h2:mt-12 prose-h2:mb-6 prose-h2:text-3xl
      ">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style is:global>
  /* Basic prose styling for those without @tailwindcss/typography installed yet */
  .prose h2 {
    font-weight: 900;
    font-size: 1.875rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
  }
  .prose p {
    margin-bottom: 1.5rem;
    line-height: 1.75;
  }
</style>
