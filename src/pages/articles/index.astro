---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowRight, Clock, Calendar, Filter, Grid, List } from 'lucide-react';

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.type !== 'hub');
const posts = allPosts.sort((a, b) => 
  new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

const pillars = [
  { id: 'grant-guides', label: 'Grant Guides', color: 'from-blue-500 to-cyan-500' },
  { id: 'grant-writing', label: 'Grant Writing', color: 'from-purple-500 to-pink-500' },
  { id: 'grants-by-industry', label: 'By Industry', color: 'from-amber-500 to-orange-500' },
  { id: 'grants-by-location', label: 'By Location', color: 'from-emerald-500 to-teal-500' },
  { id: 'grants-by-demographic', label: 'By Demographic', color: 'from-red-500 to-rose-500' },
  { id: 'grant-programs', label: 'Grant Programs', color: 'from-indigo-500 to-violet-500' },
  { id: 'grant-strategy', label: 'Grant Strategy', color: 'from-slate-500 to-gray-500' },
];
---

<BaseLayout title="All Articles | Blog">
  <main class="flex-grow bg-background">
    <!-- Hero -->
    <section class="border-b border-border bg-gradient-to-b from-background to-secondary/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
        <div class="flex items-center gap-2 text-sm text-muted-foreground mb-8">
          <a href="/blog/" class="hover:text-primary transition-colors">Home</a>
          <span>/</span>
          <span class="text-primary font-medium">All Articles</span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display text-foreground mb-4 leading-tight">
          All Articles
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl">
          Browse all {posts.length} articles across our grant writing intelligence library.
        </p>
      </div>
    </section>

    <!-- Pillar Filters -->
    <section class="border-b border-border bg-card/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-wrap gap-3 items-center">
          <span class="text-sm font-medium text-muted-foreground mr-2">Filter by:</span>
          <button class="filter-btn px-4 py-1.5 rounded-full bg-primary text-primary-foreground text-sm font-medium transition-all" data-pillar="all">
            All
          </button>
          {pillars.map(pillar => (
            <button class="filter-btn px-4 py-1.5 rounded-full bg-secondary text-foreground text-sm font-medium hover:bg-primary/20 transition-all" data-pillar={pillar.id}>
              {pillar.label}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => {
          const pillar = pillars.find(p => p.id === post.data.pillar);
          return (
            <article 
              class="article-card group bg-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
              data-pillar={post.data.pillar}
            >
              {post.data.featuredImage ? (
                <div class="aspect-[16/9] overflow-hidden">
                  <img 
                    src={post.data.featuredImage} 
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class={`aspect-[16/9] bg-gradient-to-br ${pillar?.color} bg-opacity-10 flex items-center justify-center`}>
                  <span class="text-white/30 text-4xl">📄</span>
                </div>
              )}
              
              <div class="p-6">
                <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
                  <span class={`px-2 py-0.5 rounded-full bg-gradient-to-r ${pillar?.color} bg-opacity-10 text-foreground font-medium`}>
                    {pillar?.label}
                  </span>
                  <span>•</span>
                  <span class="flex items-center gap-1">
                    <Clock class="h-3 w-3" />
                    {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </span>
                </div>
                
                <h2 class="text-lg font-bold text-foreground mb-2 group-hover:text-primary transition-colors line-clamp-2">
                  <a href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.data.slug}/`}>
                    {post.data.title}
                  </a>
                </h2>
                
                <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                
                <a 
                  href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.data.slug}/`}
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity"
                >
                  Read Article <ArrowRight class="h-4 w-4" />
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const articles = document.querySelectorAll('.article-card');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const pillar = btn.getAttribute('data-pillar');
      
      // Update active state
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-primary-foreground');
        b.classList.add('bg-secondary', 'text-foreground');
      });
      btn.classList.remove('bg-secondary', 'text-foreground');
      btn.classList.add('bg-primary', 'text-primary-foreground');
      
      // Filter articles
      articles.forEach(article => {
        if (pillar === 'all' || article.getAttribute('data-pillar') === pillar) {
          article.style.display = 'block';
        } else {
          article.style.display = 'none';
        }
      });
    });
  });
</script>
