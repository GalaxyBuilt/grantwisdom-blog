---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Calendar, Clock, ArrowRight } from 'lucide-react';

const posts = await getCollection('blog');
// Sort by date descending
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog">
  <main class="flex-grow bg-background">
    {/* Blog Hero */}
    <section class="bg-card border-b border-border py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-black text-foreground mb-4 tracking-tight">
          GrantWisdom Blog
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto font-medium">
          Insights, guides, and updates from the world of global funding and AI-powered grant writing.
        </p>
      </div>
    </section>

    {/* Blog Post Grid */}
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="group bg-card border border-border rounded-3xl overflow-hidden hover:border-accent/40 transition-all shadow-sm flex flex-col">
              <div class="aspect-video bg-muted relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-accent/10 to-transparent flex items-center justify-center">
                  <span class="text-xs font-black uppercase text-accent tracking-widest">{post.data.category}</span>
                </div>
              </div>
              <div class="p-8 flex-grow flex flex-col">
                <div class="flex items-center gap-4 text-xs text-muted-foreground mb-4 font-bold uppercase tracking-wider">
                  <span class="flex items-center gap-1"><Calendar class="w-3 h-3" /> {post.data.date}</span>
                  <span class="flex items-center gap-1"><Clock class="w-3 h-3" /> {post.data.readTime}</span>
                </div>
                <h2 class="text-2xl font-bold text-foreground mb-4 group-hover:text-accent transition-colors tracking-tight">
                  <a href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="text-muted-foreground text-sm font-medium leading-relaxed mb-6 flex-grow">
                  {post.data.excerpt}
                </p>
                <a 
                  href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.id}`} 
                  class="inline-flex items-center gap-2 text-sm font-black text-accent uppercase tracking-tighter hover:gap-3 transition-all"
                >
                  Read Full Article <ArrowRight class="w-4 h-4" />
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* Newsletter Section */}
    <section class="py-20 bg-card border-y border-border">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-black text-foreground mb-4 tracking-tight">Stay Updated</h2>
        <p class="text-muted-foreground font-medium mb-8">Get the latest grant opportunities and insights delivered to your inbox.</p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="flex-grow bg-background border border-border rounded-xl px-4 py-3 text-foreground focus:outline-none focus:ring-2 focus:ring-accent transition-all font-medium"
          />
          <button class="bg-foreground text-background font-black uppercase tracking-widest text-xs px-8 py-3 rounded-xl hover:scale-[1.02] transition-transform">
            Subscribe
          </button>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
