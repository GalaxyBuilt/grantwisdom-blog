---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Calendar, Clock, ArrowRight, Sprout } from 'lucide-react';
import { cn } from '../lib/utils';

const posts = await getCollection('blog');
// Sort by date descending
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog">
  <main class="flex-grow bg-background relative">
    {/* Featured Post Hero */}
    {posts.length > 0 && (
      <section class="relative pt-20 pb-16 overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="relative group cursor-pointer">
            <div class="absolute inset-0 bg-accent/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <a href={`/blog/${posts[0].data.pillar}/${posts[0].data.subcategory}/${posts[0].id}/`} class="relative block bg-card/40 border border-border/50 rounded-[2.5rem] overflow-hidden backdrop-blur-sm hover:border-accent/30 transition-all duration-500">
              <div class="grid grid-cols-1 lg:grid-cols-2">
                <div class="aspect-[16/10] lg:aspect-auto bg-muted relative overflow-hidden">
                  <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-transparent"></div>
                  <div class="absolute inset-0 flex items-center justify-center p-12">
                    <div class="w-full aspect-video rounded-2xl bg-background/50 backdrop-blur-md border border-white/10 shadow-2xl flex items-center justify-center">
                      <span class="text-xs font-black uppercase tracking-[0.2em] text-accent/60">Featured Article</span>
                    </div>
                  </div>
                </div>
                <div class="p-8 lg:p-16 flex flex-col justify-center">
                  <div class="flex items-center gap-3 mb-6">
                    <span class="px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-bold uppercase tracking-wider">{posts[0].data.category}</span>
                    <span class="text-muted-foreground/60 text-xs font-bold uppercase tracking-widest flex items-center gap-1.5">
                      <Clock class="w-3.5 h-3.5" /> {posts[0].data.readTime}
                    </span>
                  </div>
                  <h2 class="text-4xl lg:text-5xl font-black text-foreground mb-6 leading-[1.1] tracking-tight group-hover:text-accent transition-colors">
                    {posts[0].data.title}
                  </h2>
                  <p class="text-muted-foreground text-lg font-medium leading-relaxed mb-8 line-clamp-3">
                    {posts[0].data.excerpt}
                  </p>
                  <div class="flex items-center gap-2 text-accent font-black uppercase tracking-tighter text-sm">
                    Read Featured Article <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                  </div>
                </div>
              </div>
            </a>
          </div>
        </div>
      </section>
    )}

    {/* Category Quick Links */}
    <section class="py-12 border-y border-border/50 bg-card/20 backdrop-blur-sm sticky top-14 z-40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between gap-8">
          <div class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2 md:pb-0">
            {['All Posts', 'Trends', 'Guides', 'Success Stories', 'Updates'].map((cat, i) => (
              <button class={cn(
                "px-5 py-2 rounded-full text-sm font-bold transition-all whitespace-nowrap",
                i === 0 ? "bg-foreground text-background" : "text-muted-foreground hover:text-foreground hover:bg-secondary"
              )}>
                {cat}
              </button>
            ))}
          </div>
          <div class="hidden md:flex items-center gap-4 text-xs font-black uppercase tracking-widest text-muted-foreground/40">
            Sorted by Latest
          </div>
        </div>
      </div>
    </section>

    {/* Blog Post Grid */}
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {posts.slice(1).map((post) => (
            <article class="group relative flex flex-col">
              <a href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.id}/`} class="block flex-grow">
                <div class="aspect-[16/10] bg-muted rounded-[2rem] border border-border/50 overflow-hidden mb-8 transition-all group-hover:border-accent/30 group-hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)]">
                  <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-transparent"></div>
                  <div class="absolute top-4 left-4">
                    <span class="px-3 py-1 rounded-full bg-background/80 backdrop-blur-md text-[10px] font-black uppercase tracking-widest text-foreground border border-border/50">
                      {post.data.category}
                    </span>
                  </div>
                </div>
                <div class="px-2">
                  <div class="flex items-center gap-4 text-[10px] font-black uppercase tracking-[0.15em] text-muted-foreground/60 mb-4">
                    <span class="flex items-center gap-1.5"><Calendar class="w-3.5 h-3.5" /> {post.data.date}</span>
                    <span class="flex items-center gap-1.5"><Clock class="w-3.5 h-3.5" /> {post.data.readTime}</span>
                  </div>
                  <h3 class="text-2xl font-bold text-foreground mb-4 leading-tight group-hover:text-accent transition-colors tracking-tight">
                    {post.data.title}
                  </h3>
                  <p class="text-muted-foreground text-sm font-medium leading-relaxed mb-6 line-clamp-2">
                    {post.data.excerpt}
                  </p>
                  <div class="inline-flex items-center gap-2 text-xs font-black text-accent uppercase tracking-widest group-hover:gap-3 transition-all">
                    View Post <ArrowRight class="w-3.5 h-3.5" />
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* Rich Newsletter Section */}
    <section class="py-32 relative overflow-hidden">
      <div class="absolute inset-0 bg-accent/5 -skew-y-3 origin-center scale-110"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-background border border-border shadow-xl mb-10">
          <Sprout class="w-8 h-8 text-accent" />
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-foreground mb-6 tracking-tight leading-tight uppercase">
          Master the art of<br/><span class="text-accent">Winning Grants</span>
        </h2>
        <p class="text-muted-foreground text-lg font-medium mb-12 max-w-xl mx-auto leading-relaxed">
          Join 10,000+ builders and founders receiving our weekly deep-dives into global funding.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto p-2 bg-background border border-border rounded-2xl shadow-sm focus-within:ring-2 focus-within:ring-accent transition-all">
          <input 
            type="email" 
            placeholder="Work email address" 
            class="flex-grow bg-transparent px-4 py-3 text-foreground focus:outline-none font-medium text-sm"
          />
          <button class="bg-foreground text-background font-black uppercase tracking-[0.12em] text-[10px] px-8 py-3 rounded-xl hover:bg-accent hover:text-white transition-all shadow-lg active:scale-95">
            Join the inner circle
          </button>
        </form>
        <p class="mt-6 text-[10px] font-bold text-muted-foreground/40 uppercase tracking-widest">
          No spam. Only high-signal opportunities.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
