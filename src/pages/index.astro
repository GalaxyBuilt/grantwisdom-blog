---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { 
  ArrowRight, 
  Sparkles, 
  TrendingUp, 
  Clock, 
  BookOpen, 
  Globe, 
  Users,
  ChevronRight,
  Search,
  Filter,
  Grid,
  List,
  Star,
  Award,
  Zap,
  Brain,
  Target,
  Compass,
  Layers,
  PenTool,
  MapPin,
  Building,
  Heart,
  GraduationCap,
  FlaskConical,
  Microscope,
  Leaf,
  Palette,
  Laptop,
  Utensils,
  Briefcase,
  Medal,
  Rocket,
  DollarSign,
  Calendar,
  Bookmark,
  Share2,
  Download
} from 'lucide-react';

// Fetch all blog posts
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft && post.data.type !== 'hub')
  .sort((a, b) => 
    new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
  );

// Get featured posts (most recent 3)
const featuredPosts = posts.slice(0, 3);

// Group posts by pillar for pillar cards
const pillars = [
  { 
    id: 'grant-guides', 
    label: 'Grant Guides', 
    icon: BookOpen,
    description: 'Master the fundamentals of grant seeking with comprehensive guides',
    color: 'from-blue-500 to-cyan-500',
    count: posts.filter(p => p.data.pillar === 'grant-guides').length
  },
  { 
    id: 'grant-writing', 
    label: 'Grant Writing', 
    icon: PenTool,
    description: 'Craft compelling proposals that win funding',
    color: 'from-purple-500 to-pink-500',
    count: posts.filter(p => p.data.pillar === 'grant-writing').length
  },
  { 
    id: 'grants-by-industry', 
    label: 'By Industry', 
    icon: Building,
    description: 'Industry-specific opportunities and strategies',
    color: 'from-amber-500 to-orange-500',
    count: posts.filter(p => p.data.pillar === 'grants-by-industry').length
  },
  { 
    id: 'grants-by-location', 
    label: 'By Location', 
    icon: MapPin,
    description: 'Geographic-specific funding opportunities',
    color: 'from-emerald-500 to-teal-500',
    count: posts.filter(p => p.data.pillar === 'grants-by-location').length
  },
  { 
    id: 'grants-by-demographic', 
    label: 'By Demographic', 
    icon: Users,
    description: 'Grants for specific communities and groups',
    color: 'from-red-500 to-rose-500',
    count: posts.filter(p => p.data.pillar === 'grants-by-demographic').length
  },
  { 
    id: 'grant-programs', 
    label: 'Grant Programs', 
    icon: Award,
    description: 'Deep dives into major funding programs',
    color: 'from-indigo-500 to-violet-500',
    count: posts.filter(p => p.data.pillar === 'grant-programs').length
  },
  { 
    id: 'grant-strategy', 
    label: 'Grant Strategy', 
    icon: Target,
    description: 'Advanced strategies for maximizing funding',
    color: 'from-slate-500 to-gray-500',
    count: posts.filter(p => p.data.pillar === 'grant-strategy').length
  }
];

// Calculate reading stats
const totalArticles = posts.length;
const totalWords = posts.reduce((acc, post) => {
  // Rough estimate: 200 words per minute reading, avg article 5 min read = 1000 words
  return acc + 1000;
}, 0);
const totalReadHours = Math.round(totalWords / 200 / 60);

// Get unique tags with counts
const tagCounts = new Map();
posts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const popularTags = Array.from(tagCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tag, count]) => ({ tag, count }));

// Get posts by month for timeline
const postsByMonth = posts.reduce((acc, post) => {
  const date = new Date(post.data.publishedAt);
  const monthYear = date.toLocaleString('default', { month: 'long', year: 'numeric' });
  if (!acc[monthYear]) acc[monthYear] = [];
  acc[monthYear].push(post);
  return acc;
}, {});
const recentMonths = Object.entries(postsByMonth).slice(0, 4);
---

<BaseLayout title="Blog & Resources">
  <main class="flex-grow bg-background">
    <!-- Hero Section - Matches main site's sophistication -->
    <section class="relative overflow-hidden border-b border-border bg-gradient-to-b from-background via-background to-secondary/20">
      <!-- Background decoration -->
      <div class="absolute inset-0 bg-grid-pattern opacity-[0.02]" />
      <div class="absolute top-40 -left-20 w-80 h-80 bg-primary/5 rounded-full blur-3xl" />
      <div class="absolute bottom-20 -right-20 w-96 h-96 bg-primary/10 rounded-full blur-3xl" />
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-sm text-muted-foreground mb-8">
          <a href="https://grantwisdom.com/" class="hover:text-primary transition-colors">Home</a>
          <ChevronRight class="h-4 w-4" />
          <span class="text-primary font-medium">Blog</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left column -->
          <div>
            <!-- Pill badge -->
            <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm text-primary font-medium mb-6">
              <Sparkles class="h-3.5 w-3.5" />
              {totalArticles}+ expert articles
            </div>
            
            <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-foreground mb-6 leading-[1.05] tracking-tight">
              Grant Writing<br />
              <span class="gradient-text italic">Intelligence</span>
            </h1>
            
            <p class="text-lg text-muted-foreground max-w-xl mb-8 leading-relaxed">
              Expert guides, proven strategies, and insider knowledge to help you secure more funding. Join 50,000+ grant seekers who level up here.
            </p>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-8 mb-10">
              <div>
                <div class="text-2xl font-bold text-foreground">{totalArticles}+</div>
                <div class="text-sm text-muted-foreground">Articles</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-foreground">{totalReadHours}+</div>
                <div class="text-sm text-muted-foreground">Hours of content</div>
              </div>
              <div>
                <div class="text-2xl font-bold text-foreground">7</div>
                <div class="text-sm text-muted-foreground">Core pillars</div>
              </div>
            </div>

            <!-- Search bar -->
            <div class="relative max-w-md">
              <input 
                type="text" 
                placeholder="Search global funding articles..." 
                class="w-full h-14 pl-12 pr-4 rounded-2xl border border-border bg-card/50 backdrop-blur-sm focus:border-primary/30 focus:ring-4 focus:ring-primary/10 transition-all outline-none text-foreground placeholder:text-muted-foreground/70"
              />
              <Search class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-muted-foreground" />
              <button class="absolute right-2 top-1/2 -translate-y-1/2 px-4 py-1.5 bg-primary text-primary-foreground rounded-xl text-sm font-medium hover:bg-primary/90 transition-colors">
                Search
              </button>
            </div>
          </div>

          <!-- Right column - Featured posts cards -->
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-primary/20 to-transparent rounded-3xl blur-2xl opacity-30" />
            <div class="relative space-y-4">
              {featuredPosts.map((post, index) => (
                <a 
                  href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.data.slug}/`}
                  class="block group"
                >
                  <div class="bg-card/80 backdrop-blur-sm border border-border rounded-2xl p-5 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300">
                    <div class="flex items-start gap-4">
                      <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
                        {index === 0 ? '🔥' : index === 1 ? '📘' : '💡'}
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 text-xs text-muted-foreground mb-1">
                          <span class="capitalize">{post.data.pillar.replace(/-/g, ' ')}</span>
                          <span>•</span>
                          <span class="flex items-center gap-1">
                            <Clock class="h-3 w-3" />
                            {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                          </span>
                        </div>
                        <h3 class="font-bold text-foreground group-hover:text-primary transition-colors line-clamp-2 mb-1">
                          {post.data.title}
                        </h3>
                        <p class="text-sm text-muted-foreground line-clamp-1">
                          {post.data.description}
                        </p>
                      </div>
                      <ChevronRight class="h-5 w-5 text-muted-foreground group-hover:text-primary group-hover:translate-x-1 transition-all" />
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pillars Grid - Main navigation -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-foreground mb-4">Explore by Topic</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Seven comprehensive pillars covering everything from grant basics to advanced funding strategies
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {pillars.map((pillar) => {
          const Icon = pillar.icon;
          const pillarPosts = posts.filter(p => p.data.pillar === pillar.id);
          const subcategories = [...new Set(pillarPosts.map(p => p.data.subcategory))];
          
          return (
            <a 
              href={`/blog/${pillar.id}/`}
              class="group relative bg-card border border-border rounded-2xl p-6 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 overflow-hidden"
            >
              <!-- Gradient background on hover -->
              <div class={`absolute inset-0 bg-gradient-to-br ${pillar.color} opacity-0 group-hover:opacity-5 transition-opacity duration-500`} />
              
              <div class="relative">
                <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${pillar.color} bg-opacity-10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
                  <Icon class="h-6 w-6 text-white" />
                </div>
                
                <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
                  {pillar.label}
                </h3>
                
                <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                  {pillar.description}
                </p>
                
                <div class="flex items-center justify-between">
                  <span class="text-xs font-medium text-muted-foreground">
                    {pillar.count} articles • {subcategories.length} topics
                  </span>
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                    Explore <ArrowRight class="h-3 w-3" />
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Latest Articles with filters -->
    <section id="latest-articles" class="bg-secondary/40 border-y border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="flex items-center justify-between mb-12">
          <div>
            <h2 class="text-3xl font-bold text-foreground mb-2">Latest Articles</h2>
            <p class="text-muted-foreground">Fresh insights and updates from our team</p>
          </div>
          
          <!-- View toggle -->
          <div class="flex items-center gap-2 p-1 bg-card border border-border rounded-xl">
            <button class="p-2 rounded-lg bg-primary text-primary-foreground">
              <Grid class="h-4 w-4" />
            </button>
            <button class="p-2 rounded-lg hover:bg-secondary transition-colors text-muted-foreground">
              <List class="h-4 w-4" />
            </button>
          </div>
        </div>

        <!-- Articles grid -->
        <div class="grid lg:grid-cols-3 gap-8">
          {posts.slice(0, 6).map((post) => {
            const pillar = pillars.find(p => p.id === post.data.pillar);
            const PillarIcon = pillar?.icon || BookOpen;
            
            return (
              <a 
                href={`/blog/${post.data.pillar}/${post.data.subcategory}/${post.data.slug}`}
                class="group bg-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
              >
                {post.data.featuredImage ? (
                  <div class="aspect-[16/9] overflow-hidden">
                    <img 
                      src={post.data.featuredImage} 
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/9] bg-gradient-to-br from-primary/10 to-secondary flex items-center justify-center">
                    <PillarIcon class="h-12 w-12 text-primary/30" />
                  </div>
                )}
                
                <div class="p-6">
                  <div class="flex items-center gap-2 text-xs text-muted-foreground mb-3">
                    <span class={`px-2 py-1 rounded-full bg-gradient-to-r ${pillar?.color} bg-opacity-10 text-foreground font-medium`}>
                      {pillar?.label}
                    </span>
                    <span>•</span>
                    <span class="flex items-center gap-1">
                      <Clock class="h-3 w-3" />
                      {new Date(post.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </span>
                  </div>
                  
                  <h3 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  
                  <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                    {post.data.description}
                  </p>
                  
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-foreground">
                      {post.data.author}
                    </span>
                    <span class="inline-flex items-center gap-1 text-sm text-primary opacity-0 group-hover:opacity-100 transition-opacity">
                      Read <ArrowRight class="h-4 w-4" />
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        {/* View all button */}
        <div class="text-center mt-12">
          <a 
            href="/blog/articles/" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-card border border-border rounded-xl hover:border-primary/30 hover:shadow-lg transition-all group"
          >
            <span class="font-medium">View All Articles</span>
            <ArrowRight class="h-4 w-4 group-hover:translate-x-1 transition-transform" />
          </a>
        </div>
      </div>
    </section>

    <!-- Popular Tags & Topics -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-foreground mb-4">Popular Topics</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          Dive deep into the most discussed topics in the grant community
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-16">
        {popularTags.map(({ tag, count }) => (
          <a 
            href={`/blog/tag/${tag}/`}
            class="group px-4 py-2 bg-card border border-border rounded-full hover:border-primary/30 hover:bg-primary/5 transition-all"
          >
            <span class="text-sm font-medium text-foreground">#{tag}</span>
            <span class="text-xs text-muted-foreground ml-2">({count})</span>
          </a>
        ))}
      </div>

      <!-- Monthly archives preview -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {recentMonths.map(([month, monthPosts]) => (
          <div 
            class="group bg-card border border-border rounded-xl p-6 hover:border-primary/30 hover:shadow-lg transition-all"
          >
            <Calendar class="h-8 w-8 text-primary mb-4" />
            <h3 class="font-bold text-foreground mb-1">{month}</h3>
            <p class="text-sm text-muted-foreground mb-4">{monthPosts.length} articles</p>
            <span class="inline-flex items-center gap-1 text-xs font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity">
              Live Updates <ArrowRight class="h-3 w-3" />
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Newsletter section - Matching main site style -->
    <section class="bg-gradient-to-b from-primary/5 to-transparent border-y border-primary/10">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1.5 text-sm text-primary font-medium mb-6">
          <Sparkles class="h-4 w-4" />
          Weekly Grant Intelligence
        </div>
        
        <h2 class="font-display text-4xl text-foreground mb-4 italic">
          Stay Ahead of the Curve
        </h2>
        
        <p class="text-muted-foreground text-lg mb-8 max-w-2xl mx-auto">
          Get the latest grant opportunities, writing tips, and funding strategies delivered to your inbox every Tuesday.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="flex-1 h-12 px-4 rounded-xl border border-border bg-card focus:border-primary/30 focus:ring-4 focus:ring-primary/10 transition-all outline-none text-foreground"
          />
          <button class="h-12 px-6 bg-primary text-primary-foreground rounded-xl font-medium hover:bg-primary/90 transition-colors">
            Subscribe
          </button>
        </div>
        
        <p class="text-xs text-muted-foreground mt-4">
          Join 15,000+ grant seekers. No spam, unsubscribe anytime.
        </p>
      </div>
    </section>

    <!-- CTA Section - Match main site -->
    <section class="bg-secondary/40 border-t border-border">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 text-center">
        <h2 class="font-display text-4xl text-foreground mb-4 italic">
          Ready to find your next grant?
        </h2>
        <p class="text-muted-foreground mb-8">
          Put these insights into action. Search 200,000+ active grants right now.
        </p>
        <a href="https://grantwisdom.com/grants">
          <button class="h-14 px-8 bg-primary text-primary-foreground rounded-xl font-medium hover:bg-primary/90 transition-colors inline-flex items-center gap-2 text-lg">
            Search Grants
            <ArrowRight class="h-5 w-5" />
          </button>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(circle at 1px 1px, rgb(0 0 0 / 0.05) 1px, transparent 0);
    background-size: 40px 40px;
  }
  
  :global(.dark) .bg-grid-pattern {
    background-image: radial-gradient(circle at 1px 1px, rgb(255 255 255 / 0.05) 1px, transparent 0);
  }
</style>
