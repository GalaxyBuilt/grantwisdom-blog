---
import { Navbar } from '../components/layout/Navbar';
import { Footer } from '../components/layout/Footer';
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  author?: string;
}

const {
  title,
  description = "Search thousands of global grants with AI-powered matching. Generate high-quality grant application drafts in seconds. Find funding for startups, nonprofits, and research.",
  ogTitle = "GrantWisdom | AI-Powered Grant Search & Writing",
  ogDescription = "Access thousands of grants worldwide. Use AI to find the perfect match and draft your application.",
  image = "/og-main.png",
  type = "website",
  publishedDate,
  author = "GrantWisdom Team",
} = Astro.props;

const siteUrl = "https://grantwisdom.com";
const canonicalUrl = Astro.props.canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
const fullTitle = `${title} | GrantWisdom`;
const finalOgTitle = Astro.props.ogTitle ?? (title?.includes("Blog") || !title ? ogTitle : fullTitle);
const finalOgDescription = Astro.props.ogDescription ?? (type === 'website' ? ogDescription : description);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/blog/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/blog/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/blog/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/blog/apple-touch-icon.png" />
    <link rel="manifest" href="/blog/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="GrantWisdom" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalOgTitle} />
    <meta name="twitter:description" content={finalOgDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Article-specific -->
    {type === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={author} />
    )}

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="GrantWisdom Blog RSS" href="/blog/rss.xml" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-RHPRMVSXGK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RHPRMVSXGK');
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "GrantWisdom",
      "url": siteUrl,
      "description": "AI-Powered Grant Search & Writing Intelligence",
      "publisher": {
        "@type": "Organization",
        "name": "GrantWisdom",
        "logo": {
          "@type": "ImageObject",
          "url": `${siteUrl}/favicon.svg`
        }
      }
    })} />

    {type === 'article' && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": title,
        "description": description,
        "image": ogImage,
        "author": {
          "@type": "Person",
          "name": author
        },
        "publisher": {
          "@type": "Organization",
          "name": "GrantWisdom",
          "logo": {
            "@type": "ImageObject",
            "url": `${siteUrl}/favicon.svg`
          }
        },
        "datePublished": publishedDate,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalUrl
        }
      })} />
    )}

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": `${siteUrl}/blog`
        },
        // Only include if deeper than /blog
        ...(Astro.url.pathname !== '/blog' && Astro.url.pathname !== '/blog/' ? [
          {
            "@type": "ListItem",
            "position": 3,
            "name": title,
            "item": canonicalUrl
          }
        ] : [])
      ]
    })} />

    <!-- JSON Feed -->
    <link rel="alternate" type="application/feed+json" title="GrantWisdom Blog JSON Feed" href="/blog/feed.json" />

    <style is:global>
      :root {
        --accent-gradient: linear-gradient(
          45deg,
          hsl(var(--accent)),
          hsl(var(--accent) / 0.8) 30%,
          hsl(var(--background)) 60%
        );
      }
      
      html {
        scroll-behavior: smooth;
      }

      ::selection {
        background-color: hsl(var(--accent) / 0.2);
        color: hsl(var(--accent));
      }

      .glass-card {
        background: hsl(var(--card) / 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid hsl(var(--border) / 0.5);
      }

      .text-gradient {
        background: linear-gradient(135deg, hsl(var(--foreground)) 0%, hsl(var(--foreground) / 0.7) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
    </style>
  </head>
  <body class="antialiased font-sans bg-background text-foreground min-h-screen flex flex-col relative overflow-x-hidden">
    {/* Decorative Background Elements */}
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-accent/5 blur-[120px] rounded-full"></div>
      <div class="absolute top-[20%] -right-[10%] w-[30%] h-[30%] bg-primary/5 blur-[100px] rounded-full"></div>
    </div>
    <Navbar client:load />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>
